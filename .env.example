# lzc-clash_mihome
# Copy to .env if you want local scripts to read defaults.

# LazyCat box name (from: lzc-cli box list)
LAZYCAT_BOX=rainierserver

# Microserver SSH
MICROSERVER_HOST=rainierserver.heiyu.space
MICROSERVER_SSH_USER=root
MICROSERVER_SSH_KEY=~/.ssh/id_ed25519

# Dashboard entry (after app install)
MIHOMO_DASHBOARD_URL=https://mihomo.rainierserver.heiyu.space
