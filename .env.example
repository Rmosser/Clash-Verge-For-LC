# lzc-clash_mihome
# Copy to .env if you want local scripts to read defaults.

# LazyCat box name (from: lzc-cli box list)
LAZYCAT_BOX=rainierserver

# Microserver SSH
MICROSERVER_HOST=rainierserver.heiyu.space
MICROSERVER_SSH_USER=root
MICROSERVER_SSH_KEY=~/.ssh/id_ed25519

# Mihomo controller URL (reachable on the microserver host)
MIHOMO_CONTROLLER_URL=http://172.18.0.1:9090

# Real config (contains proxy credentials) - keep under var/private/ and do NOT commit.
MIHOMO_CONFIG_LOCAL=var/private/mihomo.config.yaml

# Optional local Country.mmdb path (will be uploaded if present).
MIHOMO_COUNTRY_MMDB_LOCAL=var/private/Country.mmdb

# 1=enable TUN (default), 0=disable TUN
MIHOMO_TUN_ENABLE=1

# Controller secret (optional; if empty, scripts will auto-generate and save to var/private/mihomo.secret)
# MIHOMO_SECRET=
MIHOMO_SECRET_FILE_LOCAL=var/private/mihomo.secret

# Pin versions (optional; default: latest)
# MIHOMO_VERSION=latest
# METACUBEXD_VERSION=latest

# Dashboard entry (after app install)
MIHOMO_DASHBOARD_URL=https://mihomo.rainierserver.heiyu.space
