[Unit]
Description=Mihomo container proxy service (172.18.0.1:17890 -> 127.0.0.1:7890)
Requires=mihomo.service
After=mihomo.service
Requires=mihomo-container-proxy.socket
After=mihomo-container-proxy.socket

[Service]
Type=notify
ExecStart=/lib/systemd/systemd-socket-proxyd 127.0.0.1:7890
User=nobody
Group=nogroup
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
